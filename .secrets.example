# PTCV Secrets File Template
# Copy this file to .secrets and fill in your credentials
# NEVER commit .secrets to version control

# Anthropic API Configuration
# Get API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# CDISC Library API Configuration (optional)
# Get API key from: https://library.cdisc.org
CDISC_LIBRARY_API_KEY=your-cdisc-library-api-key
