title: "Stage 2: Hybrid Embedding-First Section Classification (PTCV-279)"
---

flowchart TD
    PI["ProtocolIndex<br/><i>from Stage 1</i>"] --> P1
    PI --> P2

    subgraph Stage2["Stage 2: Section Classification"]
        direction TB

        subgraph Phase1["Phase 1: Search Space Bounding"]
            P1["SectionMatcher.match()<br/><i>keyword + synonym + heading<br/>+ TOC order + RAG boost</i>"]
            P1 --> KW_BASE["Keyword Baseline<br/><i>all 16 ICH sections scored</i><br/><i>bounding, not classification</i>"]
        end

        KW_BASE --> P2

        subgraph Phase2["Phase 2: Embedding Classification"]
            P2{"centroid<br/>exists?"}
            P2 -->|"B.2,3,4,5,8,16"| FAISS["FAISS Centroid Classifier<br/><i>cosine similarity scoring</i><br/><i>OVERRIDES keyword score</i>"]
            P2 -->|"B.1,6,7,9,10–15"| KW_FALL["Keyword Fallback<br/><i>uses Phase 1 scores</i>"]

            FAISS --> CONF{"embedding<br/>confidence?"}
            CONF -->|"HIGH ≥ 0.75"| ACCEPT["Accept<br/><i>no API cost</i>"]
            CONF -->|"REVIEW"| RAG["RAG Exemplar Boost<br/><i>FAISS top-3 neighbors</i><br/><i>2+ votes → +0.08</i>"]
            RAG --> CONF2{"boosted?"}
            CONF2 -->|HIGH| ACCEPT
            CONF2 -->|still REVIEW| SONNET["Sonnet Cascade<br/><i>reclassify uncertain</i>"]
            CONF -->|"LOW < 0.50"| SONNET

            KW_FALL --> KW_CONF{"keyword<br/>confidence?"}
            KW_CONF -->|HIGH| ACCEPT
            KW_CONF -->|"REVIEW/LOW"| SONNET
        end

        ACCEPT --> MR["MatchResult<br/><i>parent-level classifications</i>"]
        SONNET --> MR

        subgraph Phase3["Phase 3: Sub-Section Enrichment"]
            MR --> SUMM["SummarizationMatcher.refine()<br/><i>LLM semantic fit scoring</i><br/><i>ThreadPool + cache</i>"]
            SUMM --> SUB["Sub-Section Matches<br/><i>B.x.y granularity</i><br/><i>embed=0.45, kw=0.15, llm=0.40</i>"]
        end

        subgraph Phase4["Phase 4: Bottom-Up Propagation"]
            SUB --> BU["HIGH sub-section<br/>upgrades REVIEW parent"]
        end

        BU --> OUT["EnrichedMatchResult<br/><i>parent + sub-section scores</i><br/><i>llm_calls, coverage</i>"]
    end

    OUT --> NEXT["→ Stage 3: Query Extraction"]

